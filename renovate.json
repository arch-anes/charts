{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "bumpVersion": "patch",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "matchFileNames": ["charts/**"],
      "groupName": "helm dependencies ({{{parentDir}}})",
      "groupSlug": "helm-{{{parentDir}}}"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ]
}