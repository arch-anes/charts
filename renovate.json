{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)Chart\\.yaml$"
      ],
      "matchStrings": [
        "appVersion:\\s*\"?(?<currentValue>[^\"\\s]+)\"?\\s*#\\s*renovate:\\s*image=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "helmv3",
        "helm-values",
        "custom.regex"
      ],
      "matchFileNames": [
        "charts/**"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "schedule": ["at any time"],
      "groupName": "{{parentDir}}",
      "groupSlug": "chart-{{parentDir}}"
    },
    {
      "matchPackageNames": [
        "ghcr.io/ggml-org/llama.cpp"
      ],
      "versioning": "regex:^b(?<major>\\d+)$",
      "extractVersion": "^server-(?<version>b\\d+)$"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    }
  ]
}
